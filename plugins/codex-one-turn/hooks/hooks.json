{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${PLUGIN_ROOT}/hooks/oneturn_hook.py\"",
            "commandWindows": "python \"%PLUGIN_ROOT%\\hooks\\oneturn_hook.py\"",
            "timeout": 5,
            "statusMessage": "Checking OneTurn activation"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${PLUGIN_ROOT}/hooks/oneturn_hook.py\"",
            "commandWindows": "python \"%PLUGIN_ROOT%\\hooks\\oneturn_hook.py\"",
            "timeout": 5,
            "statusMessage": "Verifying OneTurn completion"
          }
        ]
      }
    ]
  }
}
